@page "/products/{ProductId:guid}/edit"
@implements IDisposable
@inject ProductCatalogFacade CatalogFacade
@inject NavigationManager NavigationManager

<PageTitle>Editar producto</PageTitle>

<section class="editor-shell">
    <div class="editor-header">
        <div>
            <p class="catalog-kicker">Flujo de actualizacion</p>
            <h1>Editar producto</h1>
            <p class="catalog-summary">Nombre y SKU quedan bloqueados. Precio y stock se actualizan mediante el handler con proteccion atomica ante rollback.</p>
        </div>
        <a class="btn btn-outline-secondary" href="/products">Volver al catalogo</a>
    </div>

    @if (_isLoading)
    {
        <div class="catalog-empty-state">Cargando producto...</div>
    }
    else if (_notFoundProblem is not null)
    {
        <ProblemDetailsAlert Value="_notFoundProblem" CssClass="alert-warning" />
    }
    else if (_editContext is not null)
    {
        <ProblemDetailsAlert Value="_globalProblem" />

        <div class="editor-grid">
            <div class="editor-card">
                <EditForm EditContext="_editContext" OnValidSubmit="HandleSubmitAsync" FormName="edit-product">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="validation-summary" />

                    <div class="editor-dual">
                        <div class="mb-3">
                            <label class="form-label" for="edit-name">Nombre del producto</label>
                            <InputText id="edit-name" class="form-control" @bind-Value="_model.Name" />
                            <ValidationMessage For="() => _model.Name" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="edit-sku">SKU</label>
                            <InputText id="edit-sku" class="form-control" @bind-Value="_model.Sku" />
                            @if (_isValidatingSku)
                            {
                                <div class="field-note">Verificando disponibilidad del SKU...</div>
                            }
                            <ValidationMessage For="() => _model.Sku" />
                        </div>
                    </div>

                    <div class="editor-dual">
                        <div class="mb-3">
                        <label class="form-label" for="edit-sale-price">Precio de venta</label>
                            <InputNumber id="edit-sale-price" class="form-control" @bind-Value="_model.SalePrice" />
                            <ValidationMessage For="() => _model.SalePrice" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="edit-cost">Costo</label>
                            <InputNumber id="edit-cost" class="form-control" @bind-Value="_model.Cost" />
                            <ValidationMessage For="() => _model.Cost" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label" for="edit-stock">Stock</label>
                        <InputNumber id="edit-stock" class="form-control" @bind-Value="_model.Stock" />
                        <ValidationMessage For="() => _model.Stock" />
                    </div>

                    <div class="editor-actions">
                        <button class="btn btn-primary" type="submit" disabled="@(!CanSubmit)">Guardar cambios</button>
                        <button class="btn btn-outline-secondary" type="button" @onclick="Cancel">Cancelar</button>
                    </div>
                </EditForm>
            </div>

            <aside class="editor-sidecard">
                <span class="catalog-meta-label">Resumen de cambios</span>
                <ul>
                    <li>Venta original: @_originalProduct?.SalePrice.ToString("C")</li>
                    <li>Costo original: @_originalProduct?.Cost.ToString("C")</li>
                    <li>Stock original: @_originalProduct?.Stock</li>
                    <li>Delta despues de guardar: @(StockDelta >= 0 ? $"+{StockDelta}" : StockDelta.ToString())</li>
                </ul>
            </aside>
        </div>
    }
</section>

@code {
    [Parameter]
    public Guid ProductId { get; set; }

    private ProductDto? _originalProduct;
    private ProductEditorModel _model = new();
    private EditContext? _editContext;
    private ValidationMessageStore? _messageStore;
    private CancellationTokenSource? _skuValidationCts;
    private bool _isLoading = true;
    private bool _isSubmitting;
    private bool _isValidatingSku;
    private bool _hasAsyncSkuError;
    private ProblemDetails? _globalProblem;
    private ProblemDetails? _notFoundProblem;

    private bool CanSubmit => !_isSubmitting && !_isValidatingSku && _editContext is not null && HasChanges() && !HasValidationErrors();
    private int StockDelta => _originalProduct is null ? 0 : _model.Stock - _originalProduct.Stock;

    public void Dispose()
    {
        DetachEditContext();
        _skuValidationCts?.Cancel();
        _skuValidationCts?.Dispose();
    }

    protected override async Task OnParametersSetAsync()
    {
        _isLoading = true;
        _globalProblem = null;
        _notFoundProblem = null;
        _hasAsyncSkuError = false;
        DetachEditContext();

        try
        {
            _originalProduct = await CatalogFacade.GetProductByIdAsync(ProductId);
            _model = ProductEditorModel.FromProduct(_originalProduct);
            _editContext = new EditContext(_model);
            _messageStore = new ValidationMessageStore(_editContext);
            _editContext.OnFieldChanged += HandleFieldChanged;
        }
        catch (CatalogProblemDetailsException exception)
        {
            _notFoundProblem = exception.ProblemDetails;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async void HandleFieldChanged(object? sender, FieldChangedEventArgs args)
    {
        _globalProblem = null;

        if (args.FieldIdentifier.FieldName == nameof(ProductEditorModel.Sku))
        {
            await ValidateSkuAsync();
        }
        else
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ValidateSkuAsync()
    {
        if (_editContext is null || _messageStore is null || _originalProduct is null)
        {
            return;
        }

        _skuValidationCts?.Cancel();
        _skuValidationCts?.Dispose();
        _skuValidationCts = new CancellationTokenSource();

        var token = _skuValidationCts.Token;
        var field = _editContext.Field(nameof(ProductEditorModel.Sku));
        _messageStore.Clear(field);
        _hasAsyncSkuError = false;

        if (string.IsNullOrWhiteSpace(_model.Sku))
        {
            _editContext.NotifyValidationStateChanged();
            await InvokeAsync(StateHasChanged);
            return;
        }

        _isValidatingSku = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            await Task.Delay(350, token);
            var result = await CatalogFacade.CheckSkuExistsAsync(_model.Sku, token);
            if (result.Exists && !string.Equals(result.Sku, _originalProduct.Sku, StringComparison.Ordinal))
            {
                _messageStore.Add(field, "El SKU ya existe.");
                _hasAsyncSkuError = true;
            }
        }
        catch (OperationCanceledException)
        {
            return;
        }
        catch (CatalogProblemDetailsException exception)
        {
            _messageStore.Add(field, ProblemDetailsMessageFormatter.ToUserMessage(exception.ProblemDetails));
            _hasAsyncSkuError = true;
        }
        finally
        {
            if (!token.IsCancellationRequested)
            {
                _isValidatingSku = false;
                _editContext.NotifyValidationStateChanged();
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private async Task HandleSubmitAsync()
    {
        if (_originalProduct is null || _editContext is null || !HasChanges() || _isValidatingSku || HasValidationErrors())
        {
            return;
        }

        _globalProblem = null;
        _isSubmitting = true;

        try
        {
            await CatalogFacade.UpdateProductAsync(ProductId, _model, _originalProduct, Guid.NewGuid());
            NavigationManager.NavigateTo("/products?saved=updated");
        }
        catch (CatalogProblemDetailsException exception)
        {
            _globalProblem = exception.ProblemDetails;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private bool HasChanges()
    {
        return _originalProduct is not null &&
               (_model.Name != _originalProduct.Name ||
                _model.Sku != _originalProduct.Sku ||
                _model.SalePrice != _originalProduct.SalePrice ||
                _model.Cost != _originalProduct.Cost ||
                _model.Stock != _originalProduct.Stock);
    }

    private bool HasValidationErrors()
    {
        var validationContext = new ValidationContext(_model);
        var validationResults = new List<ValidationResult>();
        return !Validator.TryValidateObject(_model, validationContext, validationResults, true) || _hasAsyncSkuError;
    }

    private void DetachEditContext()
    {
        if (_editContext is not null)
        {
            _editContext.OnFieldChanged -= HandleFieldChanged;
        }
    }

    private void Cancel()
    {
        NavigationManager.NavigateTo("/products");
    }
}
