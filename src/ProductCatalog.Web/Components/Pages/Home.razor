@page "/"

<PageTitle>Catalog Ops</PageTitle>

<section class="hero-shell">
    <div class="hero-copy">
        <p class="hero-kicker">Senior .NET technical test</p>
        <h1>Catalog control panel wired to real application flow.</h1>
        <p class="hero-summary">
            Domain rules, CQRS, SQL Server, Docker, controllers, cache metadata and Blazor all meet here.
            Next step in browser: manage products with real validation and traceable runtime behavior.
        </p>
        <div class="hero-actions">
            <a class="btn btn-primary" href="/products">Open catalog</a>
            <a class="btn btn-outline-secondary" href="/products/new">Create product</a>
        </div>
    </div>

    <div class="hero-panel">
        <div class="hero-metric">
            <span class="hero-metric-label">Coverage lane</span>
            <strong>API + UI + Infra</strong>
        </div>
        <div class="hero-metric">
            <span class="hero-metric-label">Validation lane</span>
            <strong>Unit 37 | Integration 19</strong>
        </div>
        <div class="hero-metric">
            <span class="hero-metric-label">Current focus</span>
            <strong>Product workflows</strong>
        </div>
    </div>
</section>
