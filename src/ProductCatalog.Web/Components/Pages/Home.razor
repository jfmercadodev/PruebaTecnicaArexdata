@page "/"

<PageTitle>Catalogo</PageTitle>

<section class="hero-shell">
    <div class="hero-copy">
        <p class="hero-kicker">Prueba tecnica Senior .NET</p>
        <h1>Panel de control del catalogo conectado al flujo real de la aplicacion.</h1>
        <p class="hero-summary">
            Reglas de dominio, CQRS, SQL Server, Docker, controllers, metadatos de cache y Blazor convergen aqui.
            Siguiente paso en navegador: gestionar productos con validacion real y comportamiento trazable.
        </p>
        <div class="hero-actions">
            <a class="btn btn-primary" href="/products">Abrir catalogo</a>
            <a class="btn btn-outline-secondary" href="/products/new">Crear producto</a>
        </div>
    </div>

    <div class="hero-panel">
        <div class="hero-metric">
            <span class="hero-metric-label">Cobertura</span>
            <strong>API + UI + Infra</strong>
        </div>
        <div class="hero-metric">
            <span class="hero-metric-label">Validacion</span>
            <strong>Unit 37 | Integration 19</strong>
        </div>
        <div class="hero-metric">
            <span class="hero-metric-label">Foco actual</span>
            <strong>Flujos de producto</strong>
        </div>
    </div>
</section>
